    -- Admin Commands (May not work in most games)
    function Commands.kick(args)
        if not args[1] then return "Usage: ;kick <player> [reason]" end
        
        local target = findPlayer(args[1])
        if not target then return "Player not found" end
        
        local reason = args[2] or "Kicked by Infinite Yield"
        
        warnUser("Kick command may not work in this game")
        
        local success, err = pcall(function()
            target:Kick(reason)
        end)
        
        if success then
            notify("Kick", "Kicked " .. target.Name, 2)
            return "Kicked " .. target.Name
        else
            return "Failed to kick: " .. tostring(err)
        end
    end

    function Commands.freeze(args)
        if not args[1] then return "Usage: ;freeze <player>" end
        
        local target = findPlayer(args[1])
        if not target then return "Player not found" end
        
        local char = target.Character
        if not char then return "Character not found" end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local bv = Instance.new("BodyVelocity")
            bv.Velocity = Vector3.new(0, 0, 0)
            bv.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
            bv.Parent = hrp
            notify("Freeze", "Froze " .. target.Name, 2)
            warnUser("Freeze may not work in all games")
            return "Froze " .. target.Name
        end
        return "Failed to freeze"
    end

    function Commands.unfreeze(args)
        if not args[1] then return "Usage: ;unfreeze <player>" end
        
        local target = findPlayer(args[1])
        if not target then return "Player not found" end
        
        local char = target.Character
        if not char then return "Character not found" end
        
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp then
            local bv = hrp:FindFirstChild("BodyVelocity")
            if bv then bv:Destroy() end
            notify("Unfreeze", "Unfroze " .. target.Name, 2)
            return "Unfroze " .. target.Name
        end
        return "Failed to unfreeze"
    end

    -- Utility Commands (Mostly Working)
    function Commands.chat(args)
        if not args[1] then return "Usage: ;chat <message>" end
        
        local message = table.concat(args, " ")
        
        if IsLegacyChat then
            local chat = LocalPlayer.PlayerGui:FindFirstChild("Chat")
            if chat then
                local bar = chat:FindFirstChild("Frame"):FindFirstChild("ChatBarParentFrame"):FindFirstChild("ChatBar")
                if bar then
                    bar.Text = message
                    bar:CaptureFocus()
                    local event = bar:FindFirstChild("FocusLost")
                    if event then event:Fire(true) end
                end
            end
        else
            local channel = TextChatService.TextChannels.RBXGeneral
            if channel then channel:SendAsync(message) end
        end
        
        notify("Chat", "Sent: " .. message, 2)
        return "Message sent"
    end

    function Commands.serverhop(args)
        warnUser("Server hop may not work on all executors")
        
        local servers = {}
        local response = game:HttpGetAsync("https://games.roblox.com/v1/games/" .. PlaceId .. "/servers/Public?limit=100")
        local data = HttpService:JSONDecode(response)
        
        for _, server in pairs(data.data) do
            if server.playing < server.maxPlayers and server.id ~= JobId then
                table.insert(servers, server.id)
            end
        end
        
        if #servers > 0 then
            local random = servers[math.random(1, #servers)]
            if queueteleport then
                queueteleport(random)
                notify("Server Hop", "Teleporting...", 2)
                return "Teleporting to random server"
            else
                return "Server hop not supported on this executor"
            end
        end
        return "No other servers found"
    end

