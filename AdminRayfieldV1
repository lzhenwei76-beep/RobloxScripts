    function Commands.delwaypoint(args)
        local name = args[1]
        if not name then return "Usage: ;delwp <name>" end
        
        if not Data.Waypoints[name] then return "Waypoint not found" end
        
        Data.Waypoints[name] = nil
        saveData()
        notify("Waypoint", "Deleted '" .. name .. "'", 2)
        return "Waypoint deleted"
    end

    function Commands.waypoints(args)
        local list = "=== Waypoints ===\n"
        for name, pos in pairs(Data.Waypoints) do
            list = list .. string.format("• %s → (%.1f, %.1f, %.1f)\n", name, pos.X, pos.Y, pos.Z)
        end
        if list == "=== Waypoints ===\n" then list = "No waypoints saved" end
        return list
    end

    -- Keybind Commands (May have conflicts)
    function Commands.bind(args)
        if not args[1] or not args[2] then return "Usage: ;bind <key> <command>" end
        
        local key = args[1]:upper()
        local command = table.concat(args, " ", 2)
        
        Data.Keybinds[key] = command
        saveData()
        notify("Keybind", key .. " → " .. command, 2)
        warnUser("Keybinds may conflict with game controls")
        return "Bound " .. key .. " to: " .. command
    end

    function Commands.unbind(args)
        if not args[1] then return "Usage: ;unbind <key>" end
        
        local key = args[1]:upper()
        if Data.Keybinds[key] then
            Data.Keybinds[key] = nil
            saveData()
            notify("Keybind", "Unbound " .. key, 2)
            return "Unbound " .. key
        end
        return "No keybind found for " .. key
    end

