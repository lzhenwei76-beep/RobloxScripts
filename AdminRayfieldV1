-- ========== KEYBIND HANDLER ==========
UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    
    local key = input.KeyCode.Name
    if key ~= "Unknown" and IY_KEYBINDS[key] then
        executeCommand(IY_KEYBINDS[key], {})
    end
end)

-- ========== CHARACTER HANDLER ==========
Players.LocalPlayer.CharacterAdded:Connect(function(char)
    task.wait(0.5)
    local humanoid = char:FindFirstChild("Humanoid")
    if humanoid then
        humanoid.WalkSpeed = IY_WALK_SPEED
        humanoid.JumpPower = IY_JUMP_POWER
    end
    
    if IY_FLYING then
        task.wait(1)
        executeCommand("fly", {})
    end
    if IY_NOCLIP then
        task.wait(1)
        executeCommand("noclip", {})
    end
    if IY_GOD then
        task.wait(1)
        executeCommand("god", {})
    end
end)

