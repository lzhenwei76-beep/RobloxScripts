local function cmdFly(args)
    local player = args[1] and getPlayer(args[1]) or LocalPlayer
    if not player or not player.Character then return "Player not found" end
    
    local char = player.Character
    local hrp = char:FindFirstChild("HumanoidRootPart")
    local humanoid = char:FindFirstChild("Humanoid")
    
    if not hrp or not humanoid then return "Character not ready" end
    
    if IY_FLYING then
        IY_FLYING = false
        if humanoid.PlatformStand then humanoid.PlatformStand = false end
        local bodyVelocity = hrp:FindFirstChild("BodyVelocity")
        if bodyVelocity then bodyVelocity:Destroy() end
        return "Fly disabled"
    else
        IY_FLYING = true
        IY_NOCLIP = false
        
        local bodyVelocity = Instance.new("BodyVelocity")
        bodyVelocity.MaxForce = Vector3.new(9e9, 9e9, 9e9)
        bodyVelocity.Velocity = Vector3.new(0, 0, 0)
        bodyVelocity.Parent = hrp
        
        humanoid.PlatformStand = true
        humanoid.AutoRotate = false
        
        local connection
        connection = RunService.RenderStepped:Connect(function()
            if not IY_FLYING or not hrp or not hrp.Parent then
                if connection then connection:Disconnect() end
                return
            end
            
            local camera = workspace.CurrentCamera
            local moveDirection = Vector3.new(0, 0, 0)
            
            if UserInputService:IsKeyDown(Enum.KeyCode.W) then
                moveDirection = moveDirection + camera.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.S) then
                moveDirection = moveDirection - camera.CFrame.LookVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.A) then
                moveDirection = moveDirection - camera.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.D) then
                moveDirection = moveDirection + camera.CFrame.RightVector
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.Space) then
                moveDirection = moveDirection + Vector3.new(0, 1, 0)
            end
            if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
                moveDirection = moveDirection - Vector3.new(0, 1, 0)
            end
            
            if moveDirection.Magnitude > 0 then
                moveDirection = moveDirection.Unit * IY_FLY_SPEED
            end
            
            bodyVelocity.Velocity = moveDirection
        end)
        
        return "Fly enabled (Speed: " .. IY_FLY_SPEED .. ")"
    end
end

local function cmdNoclip(args)
    local player = args[1] and getPlayer(args[1]) or LocalPlayer
    if not player or not player.Character then return "Player not found" end
    
    IY_NOCLIP = not IY_NOCLIP
    
    if IY_NOCLIP then
        local char = player.Character
        local function nocollide()
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = false
                end
            end
        end
        nocollide()
        
        local connection
        connection = char.DescendantAdded:Connect(function(desc)
            if desc:IsA("BasePart") then
                desc.CanCollide = false
            end
        end)
        
        return "Noclip enabled"
    else
        return "Noclip disabled"
    end
end

