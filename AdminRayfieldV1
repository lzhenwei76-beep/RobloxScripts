    -- Waypoint Commands (Working)
    function Commands.setwaypoint(args)
        local name = args[1]
        if not name then return "Usage: ;swp <name>" end
        
        local localChar = LocalPlayer.Character
        if not localChar then return "Character not found" end
        
        local localRoot = localChar:FindFirstChild("HumanoidRootPart")
