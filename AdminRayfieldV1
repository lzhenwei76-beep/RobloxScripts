-- Command Dispatcher
local function executeCommand(cmd, args)
    if Admin.Aliases[cmd] then
        cmd = Admin.Aliases[cmd]
    end
    
    local func = Admin.Commands[cmd]
    if func then
        func(args)
    else
        notify("Error", "Unknown command: " .. cmd .. "\nType ;help", 3)
    end
end

