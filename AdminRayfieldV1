local function LoadInfiniteYield()
    -- ========== COMPATIBILITY LAYER ==========
    local function missing(t, f, fallback)
        return type(f) == t and f or fallback
    end

    local cloneref = missing("function", cloneref, function(...) return ... end)
    local sethidden = missing("function", sethiddenproperty or set_hidden_property or set_hidden_prop)
    local gethidden = missing("function", gethiddenproperty or get_hidden_property or get_hidden_prop)
    local queueteleport = missing("function", queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport))
    local httprequest = missing("function", request or http_request or (syn and syn.request) or (http and http.request) or (fluxus and fluxus.request))
    local setclipboard = missing("function", setclipboard or toclipboard or set_clipboard or (Clipboard and Clipboard.set))
    local firetouchinterest = missing("function", firetouchinterest)
    local writefile, readfile = writefile, readfile
    local makefolder, isfolder, isfile = makefolder, isfolder, isfile
    local hookfunction = missing("function", hookfunction)
    local hookmetamethod = missing("function", hookmetamethod)
    local getnamecallmethod = missing("function", getnamecallmethod or get_namecall_method)
    local checkcaller = missing("function", checkcaller, function() return false end)
    local newcclosure = missing("function", newcclosure)
    local getgc = missing("function", getgc or get_gc_objects)

    -- ========== SERVICES ==========
    local Services = setmetatable({}, {
        __index = function(self, name)
            local success, cache = pcall(function() return cloneref(game:GetService(name)) end)
            if success then rawset(self, name, cache); return cache end
            error("Invalid Service: " .. name)
        end
    })

    local Players = Services.Players
    local UserInputService = Services.UserInputService
    local RunService = Services.RunService
    local TweenService = Services.TweenService
    local HttpService = Services.HttpService
    local TeleportService = Services.TeleportService
    local Lighting = Services.Lighting
    local ReplicatedStorage = Services.ReplicatedStorage
    local TextChatService = Services.TextChatService
    local VirtualInputManager = Services.VirtualInputManager
    local CoreGui = Services.CoreGui

    local LocalPlayer = Players.LocalPlayer
    local Mouse = LocalPlayer:GetMouse()
    local PlaceId, JobId = game.PlaceId, game.JobId

    -- Platform detection
    local IsMobile = UserInputService.TouchEnabled and not UserInputService.KeyboardEnabled
    local IsLegacyChat = TextChatService.ChatVersion == Enum.ChatVersion.LegacyChatService

    -- ========== LOAD RAYFIELD ==========
    local Rayfield = loadstring(game:HttpGet('https://raw.githubusercontent.com/lzhenwei76-beep/RayfieldCopy/refs/heads/main/source.lua'))()

    -- ========== CONFIGURATION ==========
    local Config = {
        Prefix = ";",
        KeepOpen = false,
        Notifications = true,
        SaveData = true,
        AutoLoad = true,
        Theme = "Default",
        ShowWarnings = true
    }

    -- ========== DATA STORAGE ==========
    local Data = {
        Keybinds = {},
        Aliases = {},
        Waypoints = {},
        Plugins = {},
        EventBinds = {},
        Settings = {}
    }

    -- ========== TOGGLES ==========
    local Toggles = {
        Flying = false,
        Noclip = false,
        God = false,
        InfiniteJump = false,
        ESP = false,
        Speed = 16,
        JumpPower = 50,
        FlySpeed = 50
    }

    -- ========== ENHANCED HELPER FUNCTIONS ==========
    local function split(str, delimiter)
        local result = {}
        for match in (str .. delimiter):gmatch("(.-)" .. delimiter) do
            table.insert(result, match)
        end
        return result
    end

    local function getArgs(input)
        local args = {}
        for arg in input:gmatch("%S+") do
            table.insert(args, arg)
        end
        return args
    end

    local function findPlayer(input)
        if input == "me" then return LocalPlayer end
        for _, player in ipairs(Players:GetPlayers()) do
            if player.Name:lower():find(input:lower()) then
                return player
            end
        end
        return nil
    end

    local function getAllPlayers()
        local list = {}
        for _, player in ipairs(Players:GetPlayers()) do
            if player ~= LocalPlayer then
                table.insert(list, player)
            end
        end
        return list
    end

    local function notify(title, content, duration)
        if Config.Notifications then
            pcall(function()
                Rayfield:Notify({Title = title, Content = content, Duration = duration or 3})
            end)
        end
    end

    local function warnUser(message)
        if Config.ShowWarnings then
            pcall(function()
                Rayfield:Notify({Title = "⚠️ WARNING", Content = message, Duration = 5})
            end)
        end
        print("[IY V3 WARNING] " .. message)
    end

    -- ========== SAVE/LOAD SYSTEM ==========
    local function saveData()
        if not writefile then return end
        pcall(function()
            makefolder("InfiniteYieldV3")
            writefile("InfiniteYieldV3/keybinds.json", HttpService:JSONEncode(Data.Keybinds))
            writefile("InfiniteYieldV3/aliases.json", HttpService:JSONEncode(Data.Aliases))
            writefile("InfiniteYieldV3/waypoints.json", HttpService:JSONEncode(Data.Waypoints))
            writefile("InfiniteYieldV3/settings.json", HttpService:JSONEncode(Config))
        end)
    end

    local function loadData()
        if not isfile then return end
        pcall(function()
            if isfile("InfiniteYieldV3/keybinds.json") then
                Data.Keybinds = HttpService:JSONDecode(readfile("InfiniteYieldV3/keybinds.json"))
            end
            if isfile("InfiniteYieldV3/aliases.json") then
                Data.Aliases = HttpService:JSONDecode(readfile("InfiniteYieldV3/aliases.json"))
            end
            if isfile("InfiniteYieldV3/waypoints.json") then
                Data.Waypoints = HttpService:JSONDecode(readfile("InfiniteYieldV3/waypoints.json"))
            end
            if isfile("InfiniteYieldV3/settings.json") then
                local saved = HttpService:JSONDecode(readfile("InfiniteYieldV3/settings.json"))
                for k, v in pairs(saved) do Config[k] = v end
            end
        end)
    end

    -- ========== CORE COMMANDS (Limited due to outdated status) ==========
    local Commands = {}

    -- Movement Commands (Mostly Working)
    function Commands.fly(args)
        Toggles.Flying = not Toggles.Flying
        
        if Toggles.Flying then
            local char = LocalPlayer.Character
            if not char then warnUser("Character not found for fly command"); return "Character not found" end
            
            local hrp = char:FindFirstChild("HumanoidRootPart")
            local humanoid = char:FindFirstChild("Humanoid")
            if not hrp or not humanoid then warnUser("Character not ready for fly"); return "Character not ready" end
            
            local bv = Instance.new("BodyVelocity")
            bv.MaxForce = Vector3.new(9e9, 9e9, 9e9)
            bv.Velocity = Vector3.new(0, 0, 0)
            bv.Parent = hrp
            
            humanoid.PlatformStand = true
            humanoid.AutoRotate = false
            
            local connection
            connection = RunService.RenderStepped:Connect(function()
                if not Toggles.Flying or not hrp or not hrp.Parent then
                    if connection then connection:Disconnect() end
                    return
                end
                
                local cam = workspace.CurrentCamera
                local move = Vector3.new(0, 0, 0)
                
                if UserInputService:IsKeyDown(Enum.KeyCode.W) then move = move + cam.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.S) then move = move - cam.CFrame.LookVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.A) then move = move - cam.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.D) then move = move + cam.CFrame.RightVector end
                if UserInputService:IsKeyDown(Enum.KeyCode.Space) then move = move + Vector3.new(0, 1, 0) end
                if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then move = move - Vector3.new(0, 1, 0) end
                
                bv.Velocity = move.Magnitude > 0 and move.Unit * Toggles.FlySpeed or Vector3.new(0, 0, 0)
            end)
            
            notify("Fly", "Enabled (Speed: " .. Toggles.FlySpeed .. ")", 2)
            return "Fly enabled"
        else
            local char = LocalPlayer.Character
            if char then
                local hrp = char:FindFirstChild("HumanoidRootPart")
                local humanoid = char:FindFirstChild("Humanoid")
                if hrp then
                    local bv = hrp:FindFirstChild("BodyVelocity")
                    if bv then bv:Destroy() end
                end
                if humanoid then
                    humanoid.PlatformStand = false
                    humanoid.AutoRotate = true
                end
            end
            notify("Fly", "Disabled", 2)
            return "Fly disabled"
        end
    end

    function Commands.noclip(args)
        Toggles.Noclip = not Toggles.Noclip
        
        local function setCollision(state)
            local char = LocalPlayer.Character
            if not char then return end
            for _, part in ipairs(char:GetDescendants()) do
                if part:IsA("BasePart") then
                    part.CanCollide = state
                end
            end
        end
        
        if Toggles.Noclip then
            setCollision(false)
            local connection
            connection = LocalPlayer.CharacterAdded:Connect(function()
                if Toggles.Noclip then setCollision(false) end
            end)
            notify("Noclip", "Enabled (May be unstable)", 2)
            warnUser("Noclip may be detected by anti-cheat")
            return "Noclip enabled"
        else
            setCollision(true)
            notify("Noclip", "Disabled", 2)
            return "Noclip disabled"
        end
    end

    function Commands.god(args)
        Toggles.God = not Toggles.God
        
        if Toggles.God then
            local function setupGod(char)
                local humanoid = char:FindFirstChild("Humanoid")
                if humanoid then
                    humanoid:GetPropertyChangedSignal("Health"):Connect(function()
                        if Toggles.God and humanoid then
                            humanoid.Health = humanoid.MaxHealth
                        end
                    end)
                end
            end
            
            setupGod(LocalPlayer.Character)
            LocalPlayer.CharacterAdded:Connect(setupGod)
            notify("God Mode", "Enabled (May be unstable)", 2)
            warnUser("God mode may not work in all games")
            return "God mode enabled"
        else
            notify("God Mode", "Disabled", 2)
            return "God mode disabled"
        end
    end

    function Commands.infJump(args)
        Toggles.InfiniteJump = not Toggles.InfiniteJump
        
        if Toggles.InfiniteJump then
            local connection
            connection = UserInputService.JumpRequest:Connect(function()
                if Toggles.InfiniteJump and LocalPlayer.Character then
                    local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
                    if humanoid then
                        humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
                    end
                end
            end)
            notify("Infinite Jump", "Enabled", 2)
            return "Infinite jump enabled"
        else
            notify("Infinite Jump", "Disabled", 2)
            return "Infinite jump disabled"
        end
    end

    function Commands.speed(args)
        local speed = tonumber(args[1])
        if not speed then return "Usage: ;speed <number>" end
        
        Toggles.Speed = math.clamp(speed, 16, 500)
        if LocalPlayer.Character then
            local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
            if humanoid then humanoid.WalkSpeed = Toggles.Speed end
        end
        notify("Speed", "Set to " .. Toggles.Speed, 2)
        if Toggles.Speed > 100 then warnUser("High speed may trigger anti-cheat") end
        return "Speed set to " .. Toggles.Speed
    end

    function Commands.jumppower(args)
        local power = tonumber(args[1])
        if not power then return "Usage: ;jumppower <number>" end
        
        Toggles.JumpPower = math.clamp(power, 50, 500)
