    Flag = "CmdInput",
    Callback = function(Text)
        if Text and Text ~= "" then
            if Text:sub(1, 1) == IY_PREFIX then
                local args = getArgs(Text:sub(2), 1)
                local cmd = args[1] and args[1]:lower() or ""
                table.remove(args, 1)
                executeCommand(cmd, args)
            else
                executeCommand(Text:lower(), {})
            end
        end
    end
