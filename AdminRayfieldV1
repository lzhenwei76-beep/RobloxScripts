local function executeCommand(cmd, args)
    local func = commands[cmd]
    if func then
        local result = func(args)
        if result then
            Rayfield:Notify({
                Title = "Command",
                Content = result,
                Duration = 3
            })
        end
    else
        Rayfield:Notify({
            Title = "Unknown Command",
            Content = "Type ;help for commands",
            Duration = 3
        })
    end
end

