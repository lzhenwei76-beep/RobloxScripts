    function Commands.waypoint(args)
        local name = args[1]
        if not name then return "Usage: ;wp <name>" end
        
        local pos = Data.Waypoints[name]
        if not pos then return "Waypoint not found" end
        
        local localChar = LocalPlayer.Character
        if not localChar then return "Character not found" end
        
        local localRoot = localChar:FindFirstChild("HumanoidRootPart")
        if not localRoot then return "Character not ready" end
        
        localRoot.CFrame = CFrame.new(pos)
        notify("Waypoint", "Teleported to '" .. name .. "'", 2)
