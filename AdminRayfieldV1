            local humanoid = LocalPlayer.Character:FindFirstChild("Humanoid")
            if humanoid then humanoid.JumpPower = Toggles.JumpPower end
        end
        notify("Jump Power", "Set to " .. Toggles.JumpPower, 2)
        return "Jump power set to " .. Toggles.JumpPower
    end

    function Commands.flyspeed(args)
        local speed = tonumber(args[1])
        if not speed then return "Usage: ;flyspeed <number>" end
        
        Toggles.FlySpeed = math.clamp(speed, 10, 500)
        notify("Fly Speed", "Set to " .. Toggles.FlySpeed, 2)
        return "Fly speed set to " .. Toggles.FlySpeed
    end

    -- Teleport Commands (Mostly Working)
    function Commands.tp(args)
        local target = args[1] and findPlayer(args[1])
        if not target then return "Usage: ;tp <player>" end
        
        local targetChar = target.Character
        local localChar = LocalPlayer.Character
        if not targetChar or not localChar then return "Character not found" end
        
        local targetRoot = targetChar:FindFirstChild("HumanoidRootPart")
        local localRoot = localChar:FindFirstChild("HumanoidRootPart")
        if not targetRoot or not localRoot then return "Character not ready" end
        
        localRoot.CFrame = targetRoot.CFrame * CFrame.new(0, 0, 5)
        notify("Teleport", "Teleported to " .. target.Name, 2)
        warnUser("Teleport commands may be patched in some games")
        return "Teleported to " .. target.Name
    end

