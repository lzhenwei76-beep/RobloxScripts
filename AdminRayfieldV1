    -- Alias Commands
    function Commands.addalias(args)
        if not args[1] or not args[2] then return "Usage: ;addalias <alias> <command>" end
        
        local alias = args[1]:lower()
        local command = args[2]:lower()
        
        Data.Aliases[alias] = command
        saveData()
        notify("Alias", alias .. " → " .. command, 2)
        return "Alias added: " .. alias
    end

    function Commands.delalias(args)
        if not args[1] then return "Usage: ;delalias <alias>" end
        
        local alias = args[1]:lower()
        if Data.Aliases[alias] then
            Data.Aliases[alias] = nil
            saveData()
            notify("Alias", "Deleted " .. alias, 2)
            return "Alias deleted"
        end
        return "Alias not found"
    end

