local function cmdSpam(args)
    if not args[1] or not args[2] then return "Usage: ;spam <count> <message>" end
    
    local count = tonumber(args[1])
    local message = table.concat(args, " ", 2)
    
    for i = 1, count do
        if isLegacyChat then
            local chatBar = Players.LocalPlayer.PlayerGui:FindFirstChild("Chat")
            if chatBar then
                local chatFrame = chatBar:FindFirstChild("Frame")
                if chatFrame then
                    local chatInput = chatFrame:FindFirstChild("ChatBarParentFrame"):FindFirstChild("ChatBar")
                    if chatInput then
                        chatInput.Text = message
                        chatInput:CaptureFocus()
                        local event = chatInput:FindFirstChild("FocusLost")
                        if event then
                            event:Fire(true)
                        end
                    end
                end
            end
        else
            local textChatService = game:GetService("TextChatService")
            if textChatService and textChatService.TextChannels then
                local channel = textChatService.TextChannels.RBXGeneral
                if channel then
                    channel:SendAsync(message)
                end
            end
        end
        task.wait(0.1)
    end
    return "Spammed " .. count .. " messages"
end

